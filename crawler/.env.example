# ═══════════════════════════════════════════════════════════
# MoltGraph Crawler — environment variables
# Скопируй: cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Moltbook API ──────────────────────────────────────────
# Получи ключ на https://www.moltbook.com → личный кабинет → API
MOLTBOOK_API_KEY=твой_api_ключ_тут
MOLTBOOK_BASE_URL=https://www.moltbook.com/api/v1
USER_AGENT=MoltGraphCrawler/0.1

# ── Neo4j (внешний - тот же что и у API) ──────────────────
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=твой_neo4j_пароль

# ── Crawl behaviour ───────────────────────────────────────
REQUESTS_PER_MINUTE=60
FETCH_POST_DETAILS=1
SCRAPE_AGENT_HTML=0
CRAWL_COMMENTS=1
COMMENTS_LIMIT_PER_POST=1000
FETCH_AGENT_PROFILES=1
PROFILE_LIMIT=1000
SUBMOLT_TOP_LIMIT=1000
MODERATOR_SUBMOLTS_LIMIT=1000
ENRICH_SUBMOLTS=1
ENRICH_SUBMOLTS_LIMIT=1000

# ── Profile refresh ───────────────────────────────────────
PROFILE_REFRESH_DAYS=7
PROFILE_REFRESH_LIMIT=500
