# ─── Neo4j connection ────────────────────────────────────
# For Neo4j Aura (cloud): use neo4j+s:// URI from your Aura console
# Example: NEO4J_URI=neo4j+s://abc123.databases.neo4j.io
# For self-hosted: use bolt:// or neo4j://
# Example: NEO4J_URI=bolt://neo4j.railway.internal:7687

NEO4J_URI=neo4j+s://YOUR_AURA_INSTANCE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j

# ─── Server settings ─────────────────────────────────────
PORT=3001
CORS_ORIGIN=*
